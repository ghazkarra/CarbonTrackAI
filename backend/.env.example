# Database Configuration
DATABASE_NAME = emissions_db
DATABASE_USER = root
DATABASE_PASSWORD = 
DATABASE_HOST = localhost
DATABASE_PORT = 3306


# MySQL Connection Options
# For local MySQL with default settings:
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/emissions_db

# For MySQL with specific socket (MacOS/Linux):
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/emissions_db?unix_socket=/tmp/mysql.sock

# For remote MySQL server:
# DATABASE_URL=mysql+pymysql://username:password@hostname:port/database_name

# Application Settings
API_TITLE=Industrial Emissions API
API_VERSION=1.0.0
DEBUG=True

# Optional: Server Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=True

# Optional: Logging
LOG_LEVEL=info

# Optional: Security (for production)
# SECRET_KEY=your-secret-key-here
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30